{
  "ollama": {
    "host": "http://localhost:11434",
    "timeout_seconds": 90,
    "default_models": [
      "qwen2.5:7b",
      "llama3.2:3b",
      "llama3.2:1b"
    ],
    "fetch_models_from_api": true
  },
  "titan": {
    "host": "localhost",
    "port": 50051,
    "timeout_seconds": 300,
    "default_model": "mistralai/Mistral-7B-Instruct-v0.3"
  },
  "agent": {
    "allowed_tools": [
      "read_file",
      "write_file",
      "list_dir",
      "add_reminder",
      "rag_search",
      "rag_add",
      "rag_add_file",
      "web_search"
    ]
  },
  "gui": {
    "window_width": 1280,
    "window_height": 800,
    "hardware_refresh_interval_ms": 2000,
    "connection_check_interval_ms": 10000,
    "max_context_messages": 12
  },
  "alerts": {
    "cpu_threshold_percent": 90,
    "gpu_temp_threshold_c": 85,
    "ram_threshold_percent": 95
  },
  "memory": {
    "auto_index_on_close": true,
    "recall_n_results": 3,
    "max_messages_stored": 500,
    "auto_save_interval_seconds": 30
  },
  "daemon": {
    "enabled": true,
    "check_interval_seconds": 60,
    "cpu_sustained_checks": 3
  },
  "profile": {
    "auto_update": true
  },
  "agent_system_context": false,
  "wakeword_vad_threshold": 0.01
}